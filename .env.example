# Universal Web Security Framework Configuration
# Copy this file to .env and configure for your environment

# ====================================
# Server Configuration
# ====================================

# Server ports
PORT=443
HTTPS_PORT=443
HTTP_PORT=80

# Environment (development, staging, production)
NODE_ENV=development

# Server binding (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
BIND_ADDRESS=0.0.0.0

# ====================================
# SSL/TLS Configuration
# ====================================

# SSL certificate paths (for production HTTPS)
SSL_KEY_PATH=/path/to/your/privkey.pem
SSL_CERT_PATH=/path/to/your/fullchain.pem

# Enable/disable HTTPS (true/false)
USE_HTTPS=false

# Force HTTPS redirect (true/false)
FORCE_HTTPS=false

# ====================================
# Application Configuration
# ====================================

# Base URL for your deployment
BASE_URL=http://localhost:8080

# API endpoints
API_ENDPOINT=/api/fingerprint
EXFIL_ENDPOINT=/exfil
EXFIL_FRAME_ENDPOINT=/exfil-frame

# Static file serving
STATIC_PATH=/js/

# ====================================
# Security Configuration
# ====================================

# CORS settings
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,HEAD,OPTIONS,CONNECT,TRACE
CORS_HEADERS=Content-Type,Origin,Referer,Authorization,X-Requested-With,Accept,Accept-Language,Accept-Encoding

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security headers
HSTS_MAX_AGE=31536000
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff
REFERRER_POLICY=strict-origin-when-cross-origin

# ====================================
# Logging Configuration
# ====================================

# Log file path
LOG_FILE=access.log

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Log rotation (true/false)
LOG_ROTATION=true

# Maximum log file size (in MB)
MAX_LOG_SIZE=100

# Number of log files to keep
MAX_LOG_FILES=5

# ====================================
# Data Collection Configuration
# ====================================

# Maximum request body size (in bytes)
MAX_BODY_SIZE=10485760

# Data retention period (in days)
DATA_RETENTION_DAYS=30

# Enable/disable specific collection methods
ENABLE_IMAGE_BEACON=true
ENABLE_FETCH_API=true
ENABLE_XHR_METHOD=true
ENABLE_IFRAME_METHOD=true

# ====================================
# Development Configuration
# ====================================

# Debug mode (true/false)
DEBUG=false

# Development server reload (true/false)
DEV_RELOAD=true

# Mock SSL in development (true/false)
MOCK_SSL=false

# ====================================
# Deployment Configuration
# ====================================

# Health check endpoint
HEALTH_CHECK_ENDPOINT=/health

# Metrics endpoint
METRICS_ENDPOINT=/metrics

# Process management
PM2_INSTANCES=1
PM2_MAX_MEMORY=512

# Container configuration
CONTAINER_PORT=3000
CONTAINER_HEALTH_CHECK=true

# ====================================
# External Service Configuration
# ====================================

# Database connection (if using database)
# DATABASE_URL=postgresql://user:password@host:port/database

# Redis connection (if using Redis)
# REDIS_URL=redis://host:port

# External API keys (if needed)
# EXTERNAL_API_KEY=your_api_key_here

# ====================================
# Custom Configuration
# ====================================

# Add your custom configuration variables here
# CUSTOM_VARIABLE=value

# Organization specific settings
# ORG_NAME=Your Organization
# ORG_CONTACT=security@your-org.com

# Testing configuration
# TEST_MODE=false
# TEST_DATA_PATH=/tmp/test-data
